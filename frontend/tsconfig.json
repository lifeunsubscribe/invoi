{
  // TypeScript configuration for Invoice Builder Frontend
  // This config is set up for React + Vite with strict type checking.
  // While the codebase currently uses .jsx files, this enables future
  // TypeScript adoption and provides type checking for config files.
  "compilerOptions": {
    // Target modern browsers
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    // Bundler mode (Vite)
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    // Linting - strict type checking for better code quality
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // Additional checks
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    // Type definitions for Vitest globals (describe, it, expect, etc.)
    "types": ["vitest/globals"]
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
